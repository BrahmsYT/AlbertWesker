{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback submitted to the platform.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Bug", "Feature Request", "Improvement", "Other"] },
        "status": { "type": "string", "enum": ["new", "reviewed", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "content", "category", "status", "createdAt"]
    },
    "Organization": {
      "title": "Organization",
      "description": "A tenant workspace (Bank or Company).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Bank", "Company"] },
        "subscriptionPlan": { "type": "string", "enum": ["Starter", "Professional", "Enterprise"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "subscriptionPlan", "ownerId", "createdAt"]
    },
    "Membership": {
      "title": "Membership",
      "description": "Links a user to an organization with a specific role.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "organizationId": { "type": "string" },
        "role": { "type": "string", "enum": ["Owner", "Admin", "Analyst", "Auditor", "Executive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "organizationId", "role", "createdAt"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "A cybersecurity gap assessment for an organization.",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "name": { "type": "string" },
        "frameworks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string", "enum": ["draft", "in_progress", "completed", "archived"] },
        "score": { "type": "number" },
        "maturityScore": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "name", "frameworks", "status", "createdBy", "createdAt", "updatedAt"]
    },
    "Answer": {
      "title": "Answer",
      "description": "An answer to an assessment question.",
      "type": "object",
      "properties": {
        "assessmentId": { "type": "string" },
        "organizationId": { "type": "string" },
        "questionId": { "type": "string" },
        "domain": { "type": "string" },
        "value": { "type": "string", "enum": ["Yes", "No", "Partial", "N/A", "Unanswered"] },
        "notes": { "type": "string" },
        "evidenceUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assessmentId", "organizationId", "questionId", "domain", "value", "updatedAt"]
    },
    "Finding": {
      "title": "Finding",
      "description": "A security gap or vulnerability found during an assessment or scan.",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "assessmentId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "string", "enum": ["Assessment", "External Scan", "Manual"] },
        "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low", "Info"] },
        "domain": { "type": "string" },
        "frameworkMapping": {
          "type": "array",
          "items": { "type": "string" }
        },
        "remediationGuidance": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in_progress", "done", "accepted_risk"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "title", "description", "source", "severity", "domain", "status", "createdAt"]
    },
    "Risk": {
      "title": "Risk",
      "description": "An entry in the risk register.",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "asset": { "type": "string" },
        "likelihood": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "impact": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "score": { "type": "number" },
        "owner": { "type": "string" },
        "mitigationPlan": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Mitigating", "Mitigated", "Accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "title", "description", "likelihood", "impact", "score", "status", "createdAt"]
    },
    "Action": {
      "title": "Action",
      "description": "A remediation action task.",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "findingId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "owner": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["open", "in_progress", "blocked", "done"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "title", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "organizations/{orgId}": {
      "schema": { "$ref": "#/entities/Organization" },
      "description": "Stores tenant organizations."
    },
    "memberships/{membershipId}": {
      "schema": { "$ref": "#/entities/Membership" },
      "description": "Stores user-organization relationships."
    },
    "assessments/{assessmentId}": {
      "schema": { "$ref": "#/entities/Assessment" },
      "description": "Stores assessments."
    },
    "answers/{answerId}": {
      "schema": { "$ref": "#/entities/Answer" },
      "description": "Stores answers to assessment questions."
    },
    "findings/{findingId}": {
      "schema": { "$ref": "#/entities/Finding" },
      "description": "Stores identified gaps and vulnerabilities."
    },
    "risks/{riskId}": {
      "schema": { "$ref": "#/entities/Risk" },
      "description": "Stores risk register entries."
    },
    "actions/{actionId}": {
      "schema": { "$ref": "#/entities/Action" },
      "description": "Stores remediation actions."
    },
    "feedbacks/{feedbackId}": {
      "schema": { "$ref": "#/entities/Feedback" },
      "description": "Stores user feedback."
    }
  }
}
