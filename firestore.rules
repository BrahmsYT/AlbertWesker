rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isOrgMember(orgId) {
      return isAuthenticated() && (exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId)) || isAdmin());
    }
    
    function isOrgAdmin(orgId) {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId)).data.role in ['Owner', 'Admin'] || isAdmin());
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "qasimlirenat@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.email is string && data.createdAt is string;
    }

    function isValidOrganization(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type in ['Bank', 'Company'] &&
             data.subscriptionPlan in ['Starter', 'Professional', 'Enterprise'] &&
             data.ownerId is string && data.createdAt is string;
    }

    function isValidMembership(data) {
      return data.userId is string && data.organizationId is string &&
             data.role in ['Owner', 'Admin', 'Analyst', 'Auditor', 'Executive'] &&
             data.createdAt is string;
    }

    function isValidAssessment(data) {
      return data.organizationId is string && data.name is string && data.name.size() < 100 &&
             data.frameworks is list && data.status in ['draft', 'in_progress', 'completed', 'archived'] &&
             data.createdBy is string && data.createdAt is string && data.updatedAt is string;
    }

    function isValidAnswer(data) {
      return data.assessmentId is string && data.organizationId is string &&
             data.questionId is string && data.domain is string &&
             data.value in ['Yes', 'No', 'Partial', 'N/A', 'Unanswered'] &&
             data.updatedAt is string;
    }

    function isValidFinding(data) {
      return data.organizationId is string && data.title is string && data.title.size() < 200 &&
             data.description is string && data.description.size() < 5000 &&
             data.source in ['Assessment', 'External Scan', 'Manual'] &&
             data.severity in ['Critical', 'High', 'Medium', 'Low', 'Info'] &&
             data.domain is string && data.status in ['open', 'in_progress', 'done', 'accepted_risk'] &&
             data.createdAt is string;
    }

    function isValidRisk(data) {
      return data.organizationId is string && data.title is string && data.title.size() < 200 &&
             data.description is string && data.description.size() < 5000 &&
             data.likelihood in ['Critical', 'High', 'Medium', 'Low'] &&
             data.impact in ['Critical', 'High', 'Medium', 'Low'] &&
             data.score is number &&
             data.status in ['open', 'in_progress', 'mitigated', 'accepted'] &&
             data.createdAt is string;
    }

    function isValidAction(data) {
      return data.organizationId is string && data.title is string && data.title.size() < 200 &&
             data.status in ['open', 'in_progress', 'blocked', 'done'] &&
             data.createdAt is string;
    }

    function isValidFeedback(data) {
      return data.userId is string && data.userEmail is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.category in ['Bug', 'Feature Request', 'Improvement', 'Other'] &&
             data.status in ['new', 'reviewed', 'resolved'] &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && uidNotModified();
    }

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isAuthenticated() && isValidOrganization(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOrgAdmin(orgId) && isValidOrganization(request.resource.data) && request.resource.data.ownerId == resource.data.ownerId;
    }

    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isOrgMember(resource.data.organizationId));
      allow create: if isAuthenticated() && isValidMembership(request.resource.data) && (
        (request.resource.data.userId == request.auth.uid && request.resource.data.role == 'Owner') ||
        isOrgAdmin(request.resource.data.organizationId)
      );
      allow update: if isOrgAdmin(resource.data.organizationId) && isValidMembership(request.resource.data) && request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if isOrgAdmin(resource.data.organizationId);
    }

    match /assessments/{assessmentId} {
      allow read: if resource == null || isOrgMember(resource.data.organizationId);
      allow create: if isOrgMember(request.resource.data.organizationId) && isValidAssessment(request.resource.data);
      allow update: if isOrgMember(resource.data.organizationId) && isValidAssessment(request.resource.data) && request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if isOrgAdmin(resource.data.organizationId);
    }

    match /answers/{answerId} {
      allow read: if resource == null || isOrgMember(resource.data.organizationId);
      allow create: if isOrgMember(request.resource.data.organizationId) && isValidAnswer(request.resource.data);
      allow update: if isOrgMember(resource.data.organizationId) && isValidAnswer(request.resource.data) && request.resource.data.organizationId == resource.data.organizationId;
    }

    match /findings/{findingId} {
      allow read: if resource == null || isOrgMember(resource.data.organizationId);
      allow create: if isOrgMember(request.resource.data.organizationId) && isValidFinding(request.resource.data);
      allow update: if isOrgMember(resource.data.organizationId) && isValidFinding(request.resource.data) && request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if isOrgAdmin(resource.data.organizationId);
    }

    match /risks/{riskId} {
      allow read: if resource == null || isOrgMember(resource.data.organizationId);
      allow create: if isOrgMember(request.resource.data.organizationId) && isValidRisk(request.resource.data);
      allow update: if isOrgMember(resource.data.organizationId) && isValidRisk(request.resource.data) && request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if isOrgAdmin(resource.data.organizationId);
    }

    match /actions/{actionId} {
      allow read: if resource == null || isOrgMember(resource.data.organizationId);
      allow create: if isOrgMember(request.resource.data.organizationId) && isValidAction(request.resource.data);
      allow update: if isOrgMember(resource.data.organizationId) && isValidAction(request.resource.data) && request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if isOrgAdmin(resource.data.organizationId);
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Scan Jobs - external security scans
    match /scan_jobs/{jobId} {
      allow read: if isOrgMember(resource.data.organizationId);
      allow create: if isOrgMember(request.resource.data.organizationId) && 
                       request.resource.data.organizationId is string &&
                       request.resource.data.domain is string &&
                       request.resource.data.status == 'queued';
      allow update: if isOrgMember(resource.data.organizationId) &&
                       (request.resource.data.organizationId == resource.data.organizationId &&
                        request.resource.data.status in ['queued', 'running', 'completed', 'failed', 'cancelled']);
      allow delete: if isOrgAdmin(resource.data.organizationId);
    }

    // Audit Logs - immutable append-only logs
    match /audit_logs/{logId} {
      allow read: if isOrgMember(resource.data.organizationId);
      allow create: if isOrgMember(request.resource.data.organizationId) &&
                       request.resource.data.userId is string &&
                       request.resource.data.action is string &&
                       request.resource.data.timestamp is string &&
                       request.resource.data.outcome in ['success', 'failure'];
      allow update, delete: if false; // Immutable logs
    }

    // Control Profiles - org-specific control baselines
    match /control_profiles/{profileId} {
      allow read: if isOrgMember(resource.data.organizationId);
      allow create: if isOrgMember(request.resource.data.organizationId) &&
                       request.resource.data.type in ['Bank', 'Company', 'Custom'] &&
                       request.resource.data.controls is list;
      allow update: if isOrgAdmin(resource.data.organizationId) &&
                       request.resource.data.organizationId == resource.data.organizationId;
      allow delete: if isOrgAdmin(resource.data.organizationId);
    }
  }
}
